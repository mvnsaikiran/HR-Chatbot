# ──────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT ONLY
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored — never commit real keys.
#
# PRODUCTION NOTE:
# In production, the Gemini API key should NOT be in this file.
# Instead, deploy the Firebase Cloud Function in /functions and set the key
# there via: firebase functions:secrets:set GEMINI_API_KEY
# ──────────────────────────────────────────────────────────────────────────────

# Gemini API key (dev only — proxied through Firebase Function in production)
GEMINI_API_KEY=your_gemini_api_key_here
