rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global deny-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }
    function isAdmin() {
      return isSignedIn() && getUserData(request.auth.uid).role == 'admin';
    }

    // ── Validation helpers ────────────────────────────────────────────────────
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 100
        && (data.role == 'employee' || data.role == 'admin')
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
        && (!('photoURL'     in data) || (data.photoURL     is string && data.photoURL.size()     <= 300))
        && (!('department'   in data) || (data.department   is string && data.department.size()   <=  50))
        && data.keys().hasAll(['uid', 'email', 'role'])
        && data.keys().size() <= 10;
    }

    function isValidLeave(data) {
      return data.employeeId == request.auth.uid
        && data.type in ['vacation', 'sick', 'personal', 'maternity', 'paternity']
        && data.startDate is string
        && data.endDate is string
        && data.status in ['pending', 'approved', 'rejected']
        && (!('reason' in data) || (data.reason is string && data.reason.size() <= 500))
        && data.keys().hasAll(['employeeId', 'type', 'startDate', 'endDate', 'status'])
        && data.keys().size() <= 10;
    }

    function isValidMessage(data) {
      return data.userId == request.auth.uid
        && data.sessionId is string && data.sessionId.size() <= 128
        && data.sender in ['user', 'ai']
        && data.text is string && data.text.size() <= 4000
        && data.timestamp is timestamp
        && data.keys().hasAll(['userId', 'sessionId', 'text', 'sender', 'timestamp'])
        && data.keys().size() <= 6;
    }

    function isValidSession(data) {
      return data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 120
        && data.createdAt is timestamp
        && data.lastMessageAt is timestamp
        && data.messageCount is int && data.messageCount >= 0
        && data.keys().hasAll(['userId', 'title', 'createdAt', 'lastMessageAt', 'messageCount'])
        && data.keys().size() <= 7;
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get:  if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      allow create: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().role == 'employee';          // self-signup cannot grant admin

      allow update: if (
        isOwner(userId)
          && isValidUser(incoming())
          && incoming().diff(existing()).affectedKeys()
               .hasOnly(['displayName', 'photoURL', 'department', 'status'])
      ) || isAdmin();

      // ── Chat sessions (subcollection) ────────────────────────────────────
      match /chatSessions/{sessionId} {
        allow read, delete: if isOwner(userId);
        allow create:       if isOwner(userId) && isValidSession(incoming());
        allow update:       if isOwner(userId)
          && incoming().diff(existing()).affectedKeys()
               .hasOnly(['lastMessageAt', 'messageCount', 'title']);

        // ── Messages (sub-subcollection) ───────────────────────────────────
        match /messages/{messageId} {
          allow read:   if isOwner(userId);
          allow create: if isOwner(userId) && isValidMessage(incoming());
          // Messages are immutable once written — no update/delete by employees
          allow delete: if isAdmin();
        }
      }

      // Legacy flat chatHistory (kept for backwards compatibility)
      match /chatHistory/{messageId} {
        allow read:   if isOwner(userId);
        allow create: if isOwner(userId);
      }
    }

    // ── Leave requests ────────────────────────────────────────────────────────
    match /leaveRequests/{requestId} {
      allow get:  if isSignedIn() && (isOwner(existing().employeeId) || isAdmin());
      allow list: if isSignedIn() && (isAdmin() || resource.data.employeeId == request.auth.uid);

      allow create: if isSignedIn()
        && isValidLeave(incoming())
        && incoming().employeeId == request.auth.uid
        && incoming().status == 'pending';         // can only submit as pending

      allow update: if isSignedIn() && (
        // Admin can only change status and leave a comment
        (isAdmin()
          && incoming().diff(existing()).affectedKeys()
               .hasOnly(['status', 'managerComments', 'updatedAt']))
        ||
        // Employee can edit details while still pending
        (isOwner(existing().employeeId)
          && existing().status == 'pending'
          && incoming().diff(existing()).affectedKeys()
               .hasOnly(['type', 'startDate', 'endDate', 'reason', 'updatedAt']))
      );

      allow delete: if isAdmin()
        || (isOwner(existing().employeeId) && existing().status == 'pending');
    }

    // ── Global policy document (read-only for employees) ──────────────────────
    match /settings/policies {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
